{
  "$schemaComment": "Platform paths sync across brand clones. Skin paths stay local. Prefer adding shared code under an existing platform prefix so clones pick it up automatically.",
  "platform": [
    "src/lib",
    "src/middleware.ts",
    "src/components",
    "src/app/admin",
    "src/app/ambassador",
    "src/app/api",
    "src/app/(marketing)",
    "drizzle",
    "drizzle.config.ts",
    "vitest.config.ts",
    "tsconfig.json",
    "eslint.config.mjs",
    "postcss.config.mjs",
    "next.config.ts",
    "AGENTS.md",
    ".gitignore",
    ".cursor",
    ".brand/paths.json",
    ".brand/config.json",
    ".brand/README.md",
    "scripts/brand",
    "scripts/brand-cli.mjs"
  ],
  "skin": [
    "src/lib/brand.ts",
    "src/lib/homepage.ts",
    "src/lib/mock",
    "src/lib/db/seed.ts",
    "src/app/globals.css",
    "src/app/layout.tsx",
    "tailwind.config.ts",
    "public",
    "data",
    "scripts/import-catalyst-products.mjs",
    "package.json",
    "package-lock.json",
    "README.md",
    ".env.example",
    ".brand/lineage.json",
    ".brand/CLONE_CHECKLIST.md"
  ],
  "never": [
    "node_modules",
    ".next",
    ".git",
    ".vercel",
    ".env",
    ".env.local",
    "coverage",
    "tsconfig.tsbuildinfo",
    "next-env.d.ts",
    ".DS_Store"
  ]
}
