# ── Local design mode (no Neon required) ─────────────────────────────────────
# Leave true for local UI work without a database.
# On Vercel / production: set to false (or omit) and provide DATABASE_URL.
USE_MOCK_DATA=true

# ── Auth.js (required everywhere, including mock mode) ───────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Local:
AUTH_URL=http://localhost:3000
# Production (Vercel): set to your live URL, e.g. https://cat4.vercel.app
# AUTH_URL=https://your-domain.com

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Required for production. Leave unset for local mock mode.
# Use the Neon pooled connection string (ends with ?sslmode=require).
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Vercel Blob (media uploads: hero video, product images, etc.) ────────────
# Create a Blob store in the Vercel project; token is injected automatically
# when using the Vercel Blob integration, or paste manually:
BLOB_READ_WRITE_TOKEN=

# ── Seed admin (optional — used by npm run db:seed) ──────────────────────────
SEED_ADMIN_EMAIL=admin@cat4.com
SEED_ADMIN_PASSWORD=changeme123
